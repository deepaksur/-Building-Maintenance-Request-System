projection;
strict ( 2 );
use draft;

define behavior for ZBMR_C_HDR_22IT018 alias MaintRequest
{
  use create;
  use update;
  use delete;
  use action Edit;
  use action Activate;
  use action Discard;
  use action Prepare;
  use action Resume;
  use association _MaintItem { create; with draft; }
}

define behavior for ZBMR_C_ITM_22IT018 alias MaintItem
{
  use update;
  use delete;
  use association _MaintHeader { with draft; }
}